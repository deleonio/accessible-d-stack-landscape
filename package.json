{
	"name": "accessible-d-stack-landscape",
	"version": "0.0.18",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"assign-owner-types": "node scripts/assign-owner-types.mjs",
		"backfill-sovereignty": "node scripts/backfill-sovereignty-criteria.mjs",
		"build": "tsc && vite build",
		"cap:add:android": "cap add android",
		"cap:add:ios": "cap add ios",
		"cap:open:android": "cap open android",
		"cap:open:ios": "cap open ios",
		"cap:sync": "cap sync",
		"check-unused": "knip",
		"check-updates": "ncu",
		"dev": "vite",
		"fetch-logos": "node scripts/fetch-external-logos.mjs",
		"fetch-logos:dry-run": "node scripts/fetch-external-logos.mjs --dry-run",
		"fetch-logos:update": "node scripts/fetch-external-logos.mjs --update",
		"format": "prettier --check src",
		"lint": "npm-run-all2 --parallel lint:*",
		"lint:eslint": "eslint src",
		"lint:knip": "knip",
		"lint:stylelint": "stylelint \"src/**/*.scss\"",
		"lint:ts": "tsc --noemit",
		"migrate": "node scripts/migrate-csv-to-json.mjs",
		"mobile:build": "pnpm build && cap sync",
		"postinstall": "npm-run-all2 postinstall:*",
		"postinstall:components": "cpy \"node_modules/@public-ui/components/assets/**/*\" public/assets --dot",
		"postinstall:generate": "pnpm run prebuild",
		"postinstall:theme-kern": "cpy \"node_modules/@public-ui/theme-kern/assets/**/*\" public/assets --dot",
		"prebuild": "node scripts/generate-data.mjs && node scripts/generate-icons.mjs",
		"prepare": "husky",
		"preview": "vite preview",
		"report-dependency-health": "node scripts/report-dependency-health.mjs",
		"start": "pnpm run dev",
		"stylelint": "stylelint \"src/**/*.scss\"",
		"test": "vitest",
		"test:coverage": "vitest --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:update-snapshots": "playwright test --update-snapshots",
		"update": "ncu -u && pnpm i",
		"validate-logos": "node scripts/validate-logo-urls.mjs",
		"validate-logos:report": "node scripts/validate-logo-urls.mjs --report",
		"validate-schemas": "node scripts/validate-schemas.mjs",
		"validate-schemas:cycles": "node scripts/validate-schemas.mjs --check-cycles"
	},
	"dependencies": {
		"@capacitor/core": "8.3.1",
		"@hookform/resolvers": "5.2.2",
		"@public-ui/components": "4.1.2",
		"@public-ui/preact": "4.1.2",
		"@public-ui/react": "4.1.2",
		"@public-ui/theme-default": "4.1.2",
		"@public-ui/theme-kern": "4.1.2",
		"i18next": "26.0.6",
		"i18next-browser-languagedetector": "8.2.1",
		"preact": "10.29.1",
		"preact-iso": "2.11.1",
		"preact-render-to-string": "6.6.7",
		"react-hook-form": "7.72.1",
		"react-i18next": "17.0.4",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.2",
		"@capacitor/android": "8.3.1",
		"@capacitor/cli": "8.3.1",
		"@capacitor/ios": "8.3.1",
		"@eslint/js": "10.0.1",
		"gray-matter": "4.0.3",
		"markdown-it": "14.1.0",
		"@playwright/test": "1.59.1",
		"@preact/preset-vite": "2.10.5",
		"@typescript-eslint/eslint-plugin": "8.58.2",
		"@typescript-eslint/parser": "8.58.2",
		"@unocss/preset-mini": "66.6.8",
		"@unocss/vite": "66.6.8",
		"ajv": "8.18.0",
		"ajv-formats": "3.0.1",
		"cpy-cli": "7.0.0",
		"eslint": "10.2.1",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-react-hooks": "7.1.1",
		"husky": "9.1.7",
		"knip": "6.4.1",
		"lint-staged": "16.4.0",
		"npm-check-updates": "21.0.2",
		"npm-run-all2": "8.0.4",
		"prettier": "3.8.3",
		"prettier-plugin-organize-imports": "4.3.0",
		"sass-embedded": "1.99.0",
		"sharp": "0.34.5",
		"stylelint": "17.8.0",
		"stylelint-config-standard-scss": "17.0.0",
		"typescript": "6.0.3",
		"unocss": "66.6.8",
		"vite": "8.0.8",
		"vite-plugin-pwa": "1.2.0",
		"vitest": "4.1.4",
		"workbox-window": "7.4.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"@public-ui/components",
			"esbuild",
			"sharp"
		]
	},
	"knip": {
		"ignoreIssues": {
			"src/data/*.generated.ts": [
				"exports"
			]
		}
	},
	"lint-staged": {
		"src/**/*.{tsx,ts}": [
			"eslint --fix",
			"prettier --write"
		],
		"src/**/*.scss": [
			"stylelint --fix",
			"prettier --write"
		]
	}
}
