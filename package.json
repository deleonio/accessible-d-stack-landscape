{
	"name": "accessible-d-stack-landscape",
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"build": "tsc && vite build",
		"check-unused": "knip",
		"check-updates": "ncu",
		"dev": "vite",
		"eslint": "eslint src",
		"format": "prettier --check src",
		"lint": "tsc --noemit",
		"stylelint": "stylelint \"src/**/*.scss\"",
		"prebuild": "npm-run-all2 prebuild:*",
		"prebuild:components": "cpy \"node_modules/@public-ui/components/assets/**/*\" assets --dot",
		"prebuild:theme-kern": "cpy \"node_modules/@public-ui/theme-kern/assets/**/*\" assets --dot",
		"prepare": "pnpm prebuild",
		"preview": "vite preview",
		"start": "pnpm run dev",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:update-snapshots": "playwright test --update-snapshots",
		"update": "ncu -u && pnpm i"
	},
	"dependencies": {
		"@public-ui/components": "4.1.2",
		"@public-ui/react-v19": "4.1.2",
		"@public-ui/theme-kern": "^4.1.2",
		"react": "19.2.4",
		"react-dom": "19.2.4"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.10.2",
		"@eslint/js": "9.39.4",
		"@playwright/test": "1.51.1",
		"@types/react": "18.3.28",
		"@types/react-dom": "18.3.7",
		"@typescript-eslint/eslint-plugin": "8.58.0",
		"@typescript-eslint/parser": "8.58.0",
		"@unocss/vite": "66.6.7",
		"@vitejs/plugin-react-swc": "4.3.0",
		"cpy-cli": "6.0.0",
		"eslint": "9.39.4",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.0.1",
		"knip": "5.88.1",
		"npm-check-updates": "18.3.1",
		"npm-run-all2": "8.0.4",
		"prettier": "3.8.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"stylelint": "^17.6.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"typescript": "6.0.2",
		"unocss": "0.65.4",
		"vite": "6.4.1"
	}
}
