{
	"name": "accessible-d-stack-landscape",
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"build": "tsc && vite build",
		"check-unused": "knip",
		"check-updates": "ncu",
		"dev": "vite",
		"eslint": "eslint src",
		"format": "prettier --check src",
		"lint": "tsc --noemit",
		"stylelint": "stylelint \"src/**/*.scss\"",
		"prebuild": "npm-run-all2 prebuild:*",
		"prebuild:components": "cpy \"node_modules/@public-ui/components/assets/**/*\" assets --dot",
		"prebuild:theme-kern": "cpy \"node_modules/@public-ui/theme-kern/assets/**/*\" assets --dot",
		"prepare": "pnpm prebuild",
		"preview": "vite preview",
		"start": "pnpm run dev",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:update-snapshots": "playwright test --update-snapshots",
		"update": "ncu -u && pnpm i",
		"cap:add:android": "cap add android",
		"cap:add:ios": "cap add ios",
		"cap:sync": "cap sync",
		"cap:open:android": "cap open android",
		"cap:open:ios": "cap open ios",
		"mobile:build": "pnpm build && cap sync"
	},
	"dependencies": {
		"@capacitor/core": "^8.3.0",
		"@hookform/resolvers": "^3.3.0",
		"@public-ui/components": "4.1.2",
		"@public-ui/preact": "^4.1.2",
		"@public-ui/theme-kern": "^4.1.2",
		"preact": "^10.29.1",
		"react-hook-form": "^7.48.0",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.1",
		"@capacitor/android": "^8.3.0",
		"@capacitor/cli": "^8.3.0",
		"@capacitor/ios": "^8.3.0",
		"@eslint/js": "10.0.1",
		"@playwright/test": "1.59.1",
		"@preact/preset-vite": "^2.10.5",
		"@typescript-eslint/eslint-plugin": "8.58.0",
		"@typescript-eslint/parser": "8.58.0",
		"@unocss/vite": "66.6.7",
		"cpy-cli": "7.0.0",
		"eslint": "10.2.0",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.0.1",
		"knip": "6.3.0",
		"npm-check-updates": "20.0.0",
		"npm-run-all2": "8.0.4",
		"prettier": "3.8.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"stylelint": "^17.6.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"typescript": "6.0.2",
		"unocss": "66.6.7",
		"vite": "8.0.3",
		"vite-plugin-pwa": "^1.2.0"
	}
}
