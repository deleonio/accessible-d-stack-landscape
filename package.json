{
	"name": "accessible-d-stack-landscape",
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"build": "tsc && vite build",
		"check-unused": "knip",
		"check-updates": "ncu",
		"dev": "vite",
		"eslint": "eslint src",
		"fetch-logos": "node scripts/fetch-external-logos.mjs",
		"fetch-logos:update": "node scripts/fetch-external-logos.mjs --update",
		"fetch-logos:dry-run": "node scripts/fetch-external-logos.mjs --dry-run",
		"format": "prettier --check src",
		"lint": "tsc --noemit",
		"stylelint": "stylelint \"src/**/*.scss\"",
		"validate-logos": "node scripts/validate-logo-urls.mjs",
		"validate-logos:report": "node scripts/validate-logo-urls.mjs --report",
		"postinstall": "npm-run-all2 postinstall:*",
		"postinstall:generate": "pnpm run prebuild",
		"postinstall:components": "cpy \"node_modules/@public-ui/components/assets/**/*\" public/assets --dot",
		"postinstall:theme-default": "cpy \"node_modules/@public-ui/theme-default/assets/**/*\" public/assets --dot",
		"prebuild": "node scripts/generate-articles.mjs && node scripts/generate-icons.mjs",
		"prepare": "husky install",
		"preview": "vite preview",
		"start": "pnpm run dev",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:update-snapshots": "playwright test --update-snapshots",
		"update": "ncu -u && pnpm i",
		"cap:add:android": "cap add android",
		"cap:add:ios": "cap add ios",
		"cap:sync": "cap sync",
		"cap:open:android": "cap open android",
		"cap:open:ios": "cap open ios",
		"mobile:build": "pnpm build && cap sync"
	},
	"dependencies": {
		"@capacitor/core": "8.3.0",
		"@hookform/resolvers": "5.2.2",
		"@public-ui/components": "4.1.2",
		"@public-ui/preact": "4.1.2",
		"@public-ui/theme-default": "4.1.2",
		"preact": "10.29.1",
		"react-hook-form": "7.72.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.1",
		"@capacitor/android": "8.3.0",
		"@capacitor/cli": "8.3.0",
		"@capacitor/ios": "8.3.0",
		"@eslint/js": "10.0.1",
		"@playwright/test": "1.59.1",
		"@preact/preset-vite": "2.10.5",
		"@typescript-eslint/eslint-plugin": "8.58.0",
		"@typescript-eslint/parser": "8.58.0",
		"@unocss/vite": "66.6.7",
		"cpy-cli": "7.0.0",
		"eslint": "10.2.0",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-react-hooks": "7.0.1",
		"husky": "9.1.7",
		"knip": "6.3.0",
		"lint-staged": "16.4.0",
		"npm-check-updates": "20.0.0",
		"npm-run-all2": "8.0.4",
		"prettier": "3.8.1",
		"prettier-plugin-organize-imports": "4.3.0",
		"sass-embedded": "1.99.0",
		"sharp": "0.34.5",
		"stylelint": "17.6.0",
		"stylelint-config-standard-scss": "17.0.0",
		"typescript": "6.0.2",
		"unocss": "66.6.7",
		"vite": "8.0.5",
		"vite-plugin-pwa": "1.2.0"
	},
	"lint-staged": {
		"src/**/*.{tsx,ts}": [
			"eslint --fix",
			"prettier --write"
		],
		"src/**/*.scss": [
			"stylelint --fix",
			"prettier --write"
		]
	}
}
